# Copy to .env.local and fill in. .env.local is gitignored. NEVER commit real values.

# ── InsForge backend ────────────────────────────────────────────────
INSFORGE_API_BASE_URL=https://dsc7y62h.us-east.insforge.app
VITE_INSFORGE_API_BASE_URL=https://dsc7y62h.us-east.insforge.app
# Public anon key for the web client AND the MCP server's Stripe checkout
# (payments require a user/anon token, not the admin key).
VITE_INSFORGE_ANON_KEY=
# Server-side anon key for the MCP server in production (locally it falls back
# to VITE_INSFORGE_ANON_KEY from this file). Same value as the anon key.
INSFORGE_ANON_KEY=
# Server-side admin key (MCP catalog reads + invoking edge functions). The CLI
# also stores it in .insforge/project.json (gitignored). Do NOT expose to the browser.
INSFORGE_API_KEY=

# ── AI design generation ────────────────────────────────────────────
# Generation runs inside the `generate-design` InsForge EDGE FUNCTION, so the
# model keys live as InsForge SECRETS (not in this file). Set them once via the CLI:
#   bunx @insforge/cli secrets add GOOGLE_AI_API_KEY <key>     # Gemini image model (primary)
#   bunx @insforge/cli secrets add OPENAI_API_KEY    <key>     # gpt-image-1 fallback + prompt moderation
# Optional model overrides (also secrets): GOOGLE_IMAGE_MODEL, OPENAI_IMAGE_MODEL.

# ── Stripe (TEST mode only) ─────────────────────────────────────────
# Configured on the InsForge backend (stored as backend secrets), not here:
#   bunx @insforge/cli payments config        # sets the test secret key
#   bunx @insforge/cli payments webhooks       # surfaces the webhook secret
# The browser/MCP only ever use the anon key above to create checkout sessions.

# ── MCP server ──────────────────────────────────────────────────────
MCP_PORT=8788
MCP_PUBLIC_URL=                 # tunnel or deployed URL ChatGPT connects to
# Where Stripe returns the buyer after MCP checkout (defaults to the web studio).
WEB_APP_URL=http://localhost:5173
CHECKOUT_SUCCESS_URL=
CHECKOUT_CANCEL_URL=
MCP_OAUTH_ISSUER=               # fill once MCP auth approach is chosen
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=

# ── Print-on-demand (only if real fulfillment chosen — see ADR 0001) ─
PRINTFUL_API_KEY=
# PRINTIFY_API_KEY=

# ── Tunnel (only if ngrok chosen for local ChatGPT testing) ─────────
NGROK_AUTHTOKEN=
