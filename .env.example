# Copy to .env.local and fill in. .env.local is gitignored. NEVER commit real values.

# ── InsForge backend ────────────────────────────────────────────────
INSFORGE_API_BASE_URL=https://dsc7y62h.us-east.insforge.app
VITE_INSFORGE_API_BASE_URL=https://dsc7y62h.us-east.insforge.app
# Public anon key for the web client — confirm exact var via the `insforge` skill / `insforge docs auth`
VITE_INSFORGE_ANON_KEY=
# Server-side key (MCP server / edge functions). The CLI also stores it in .insforge/project.json (gitignored).
# Do NOT expose to the browser.
INSFORGE_API_KEY=

# ── Stripe (TEST mode only) ─────────────────────────────────────────
# Set into InsForge via: insforge payments config
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Surfaced by: insforge payments webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── MCP server ──────────────────────────────────────────────────────
MCP_PORT=8788
MCP_PUBLIC_URL=                 # tunnel or deployed URL ChatGPT connects to
MCP_OAUTH_ISSUER=               # fill once MCP auth approach is chosen
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=

# ── Print-on-demand fulfillment (Printful — see ADR 0001 D1) ────────
# Printful private token (Developer Portal → Your tokens). Empty = mock fulfillment.
PRINTFUL_API_KEY=
# Only for ACCOUNT-level tokens (multi-store); store-level tokens don't need it.
PRINTFUL_STORE_ID=
# "true" submits real (charged) orders; anything else creates free DRAFT orders. Keep false until ready.
PRINTFUL_CONFIRM_ORDERS=false
# Optional override: "printful" | "mock". Defaults to printful-when-key-present.
FULFILLMENT_PROVIDER=
# Shared secret the fulfill-order edge function requires (set as an InsForge secret too).
FULFILL_SECRET=
# PRINTIFY_API_KEY=   # swappable second adapter (not yet implemented)

# ── MCP demo wiring (until MCP OAuth lands) ─────────────────────────
# A real auth.users id the MCP server attributes carts/orders to during local dev.
DEMO_USER_ID=
# Base URL used for Stripe Checkout success/cancel redirects.
WEB_APP_URL=http://localhost:5173

# ── Tunnel (only if ngrok chosen for local ChatGPT testing) ─────────
NGROK_AUTHTOKEN=

# ── AI design generation ────────────────────────────────────────────
# Prefer the InsForge AI gateway (insforge ai). External key only if used directly.
OPENAI_API_KEY=
