# Copy to .env.local and fill in. .env.local is gitignored. NEVER commit real values.

# ── InsForge backend ────────────────────────────────────────────────
INSFORGE_API_BASE_URL=https://dsc7y62h.us-east.insforge.app
VITE_INSFORGE_API_BASE_URL=https://dsc7y62h.us-east.insforge.app
# Public anon key for the web client — confirm exact var via the `insforge` skill / `insforge docs auth`
VITE_INSFORGE_ANON_KEY=
# Server-side key (MCP server / edge functions). The CLI also stores it in .insforge/project.json (gitignored).
# Do NOT expose to the browser.
INSFORGE_API_KEY=

# ── Stripe (TEST mode only) ─────────────────────────────────────────
# Set into InsForge via: insforge payments config
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Surfaced by: insforge payments webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── MCP server ──────────────────────────────────────────────────────
MCP_PORT=8788
MCP_PUBLIC_URL=                 # tunnel or deployed URL ChatGPT connects to
MCP_OAUTH_ISSUER=               # fill once MCP auth approach is chosen
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=

# ── Print-on-demand (only if real fulfillment chosen — see ADR 0001) ─
PRINTFUL_API_KEY=
# PRINTIFY_API_KEY=

# ── Tunnel (only if ngrok chosen for local ChatGPT testing) ─────────
NGROK_AUTHTOKEN=

# ── AI design generation ────────────────────────────────────────────
# Prefer the InsForge AI gateway (insforge ai). External key only if used directly.
OPENAI_API_KEY=
