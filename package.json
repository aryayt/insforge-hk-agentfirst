{
  "name": "insforge-hk-agentfirst",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@insforge/sdk": "latest"
  },
  "scripts": {
    "mcp:dev": "bun --filter '@app/mcp' dev",
    "web:dev": "bun --filter '@app/web' dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "bun --filter '*' lint"
  }
}
