{
  "name": "insforge-hk-agentfirst",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@app/shared": "workspace:*",
    "@insforge/sdk": "latest",
    "@types/node": "latest",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "mcp:dev": "bun --filter '@app/mcp' dev",
    "web:dev": "bun --filter '@app/web' dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck && bun run typecheck:scripts",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json",
    "lint": "bun --filter '*' lint",
    "printful:check": "bun scripts/printful/cli.ts check",
    "printful:discover": "bun scripts/printful/cli.ts discover",
    "printful:variants": "bun scripts/printful/cli.ts variants",
    "printful:design": "bun scripts/printful/cli.ts design",
    "printful:mockup": "bun scripts/printful/cli.ts mockup",
    "printful:estimate": "bun scripts/printful/cli.ts estimate",
    "printful:order": "bun scripts/printful/cli.ts order",
    "printful:confirm": "bun scripts/printful/cli.ts confirm",
    "printful:order-status": "bun scripts/printful/cli.ts order-status"
  }
}
